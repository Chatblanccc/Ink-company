generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  SALES
  ANALYST
}

enum InquiryStatus {
  NEW
  QUALIFIED
  FOLLOW_UP
  CLOSED
}

enum ArticleType {
  NEWS
  CASE_STUDY
  INSIGHT
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id                    String   @id @default("site")
  companyName           Json
  address               Json
  phone                 String
  email                 String
  defaultSeoTitle       Json
  defaultSeoDescription Json
  heroTitle             Json
  heroDescription       Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ProductCategory {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        Json
  description Json?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String          @id @default(cuid())
  slug           String          @unique
  categoryId     String
  title          Json
  summary        Json
  heroTag        Json
  seoTitle       Json
  seoDescription Json
  applications   Json
  features       Json
  specifications Json
  featured       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Article {
  id             String      @id @default(cuid())
  slug           String      @unique
  type           ArticleType @default(INSIGHT)
  category       Json
  title          Json
  excerpt        Json
  content        Json
  seoTitle       Json
  seoDescription Json
  publishedAt    DateTime
  featured       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String
  market    String
  message   String
  language  String
  status    InquiryStatus @default(NEW)
  source    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
